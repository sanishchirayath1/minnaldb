{
  "name": "minnaldb-electron-demo",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Electron + React notes app demonstrating minnaldb-electron",
  "main": "out/main/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "electron-rebuild --module-dir ../.. -f -w better-sqlite3"
  },
  "dependencies": {
    "minnaldb": "workspace:*",
    "minnaldb-electron": "workspace:*",
    "minnaldb-react": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.10"
  }
}
