{
  "name": "minnaldb",
  "version": "0.0.1",
  "description": "Lightning-fast reactive SQLite for Electron, built on better-sqlite3",
  "license": "MIT",
  "author": "Sanish Chirayath",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanishchirayath1/minnaldb.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sanishchirayath1/minnaldb#readme",
  "bugs": "https://github.com/sanishchirayath1/minnaldb/issues",
  "keywords": ["sqlite", "reactive", "electron", "better-sqlite3", "database", "orm", "typesafe"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "import": "./dist/wire.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
}
